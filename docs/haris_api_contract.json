        "method": "POST",
        "path": "/api/auth/login/",
        "description": "Exchange username and password for JWT access and refresh tokens.",
        "auth_required": false,
        "permissions": ["public"],
        "query_params": [],
        "path_params": [],
        "request_body": {"username": "admin", "password": "change-me"},
        "response_body": {"access": "<access_token>", "refresh": "<refresh_token>"},
        "error_examples": {"401": {"detail": "No active account found with the given credentials"}},
        "frontend_usage_notes": "Store the access token for API calls and use the refresh token at /api/auth/refresh/."
      },
      {
        "name": "refresh_token",
        "method": "POST",
        "path": "/api/auth/refresh/",
        "description": "Refresh an expired access token.",
        "auth_required": false,
        "permissions": ["public"],
        "query_params": [],
        "path_params": [],
        "request_body": {"refresh": "<refresh_token>"},
        "response_body": {"access": "<new_access_token>"},
        "error_examples": {"401": {"detail": "Token is invalid or expired", "code": "token_not_valid"}},
        "frontend_usage_notes": "Call when an authenticated API returns 401 due to an expired access token."
      },
      {
        "name": "current_user",
        "method": "GET",
        "path": "/api/auth/me/",
        "description": "Return the authenticated user profile and role.",
        "auth_required": true,
        "permissions": ["authenticated"],
        "query_params": [],
        "path_params": [],
        "request_body": null,
        "response_body": {"id": 1, "username": "admin", "email": "admin@example.com", "first_name": "", "last_name": "", "role": "ADMIN", "is_staff": true},
        "error_examples": {"401": {"detail": "Authentication credentials were not provided."}},
        "frontend_usage_notes": "Use after login to drive role-aware navigation and permissions."
